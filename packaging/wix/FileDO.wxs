<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
      Name="FileDO"
      Manufacturer="Serhii Zhyhunenko"
      Version="$(var.ProductVersion)"
      UpgradeCode="4d6b3b1f-7c8e-4a25-9f1d-8e3b2c5a7d91"
      Scope="perMachine"
      Compressed="yes"
      InstallerVersion="500">

    <SummaryInformation Description="FileDO - Advanced File and Storage Operations Tool" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of FileDO is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPHELPLINK" Value="https://github.com/SerZhyAle/FileDO/issues" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/SerZhyAle/FileDO" />
    <Property Id="ARPCONTACT" Value="https://github.com/SerZhyAle" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ARPNOMODIFY" Value="1" />

    <Feature Id="Main" Title="FileDO" Level="1" Display="expand"
             Description="FileDO CLI binaries and helper scripts.">
      <ComponentGroupRef Id="FileDOFiles" />
      <ComponentRef Id="EnvPath" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="FileDO" />
    </StandardDirectory>

  </Package>

  <Fragment>
    <Component Id="EnvPath" Directory="INSTALLFOLDER" Guid="b9f47a02-2d5e-4f1c-90a3-1c6e8d7b4a2f">
      <Environment Id="UpdatePath"
                   Name="PATH"
                   Value="[INSTALLFOLDER]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
      <RegistryValue Root="HKLM"
                     Key="Software\FileDO"
                     Name="InstallPath"
                     Type="string"
                     Value="[INSTALLFOLDER]"
                     KeyPath="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="FileDOFiles" Directory="INSTALLFOLDER">
      <Component Id="FileDoExe" Guid="*">
        <File Source="$(var.StageDir)\filedo.exe" KeyPath="yes" />
      </Component>
      <Component Id="FileDoCheckExe" Guid="*">
        <File Source="$(var.StageDir)\filedo_check.exe" KeyPath="yes" />
      </Component>
      <Component Id="FileDoFillExe" Guid="*">
        <File Source="$(var.StageDir)\filedo_fill.exe" KeyPath="yes" />
      </Component>
      <Component Id="FileDoTestExe" Guid="*">
        <File Source="$(var.StageDir)\filedo_test.exe" KeyPath="yes" />
      </Component>
      <Component Id="FileDoCdBat" Guid="*">
        <File Source="$(var.StageDir)\filedo_cd.bat" KeyPath="yes" />
      </Component>
      <Component Id="FileDoCleanBat" Guid="*">
        <File Source="$(var.StageDir)\filedo_clean.bat" KeyPath="yes" />
      </Component>
      <Component Id="FileDoFillBat" Guid="*">
        <File Source="$(var.StageDir)\filedo_fill.bat" KeyPath="yes" />
      </Component>
      <Component Id="FileDoSpeedBat" Guid="*">
        <File Source="$(var.StageDir)\filedo_speed.bat" KeyPath="yes" />
      </Component>
      <Component Id="FileDoTestBat" Guid="*">
        <File Source="$(var.StageDir)\filedo_test.bat" KeyPath="yes" />
      </Component>
      <Component Id="LicenseFile" Guid="*">
        <File Source="$(var.StageDir)\LICENSE" Name="LICENSE.txt" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeFile" Guid="*">
        <File Source="$(var.StageDir)\README.md" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
